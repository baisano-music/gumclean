# Kopieer naar .env.local en vul in. Zet dezelfde waarden ook in
# Vercel → Project → Settings → Environment Variables (of via `vercel env add`).

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Bezorgadres van offerteaanvragen (waar jij ze leest). Vul je eigen inbox in.
OFFERTE_TO=jouw-inbox@gmail.com

# Afzender. Test zonder DNS: "GumClean <onboarding@resend.dev>".
# Na domeinverificatie bij Resend bijv.: "GumClean <offerte@gumclean.nl>".
OFFERTE_FROM=GumClean <onboarding@resend.dev>
